# Supabase — projeto gc-dev (desenvolvimento) ou gc-prod (produção)
# Copie este arquivo pra .env.local e preencha com as credenciais reais.
# Settings → API no painel do Supabase.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — apenas para uso server-side (Route Handlers, Server Actions).
# NUNCA exponha essa chave no client. Não prefixar com NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
